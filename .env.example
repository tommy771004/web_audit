# Client API endpoints
VITE_AUDIT_ENDPOINT=/api/audit
VITE_INTAKE_ENDPOINT=/api/intake

# OpenRouter synthesis
OPENROUTER_API_KEY=
ALLOW_PAID_FALLBACK=false

# Browser evidence collection
# Set to webwright to read a Webwright run folder or explicit artifact paths.
BROWSER_COLLECTOR_MODE=webwright

# Default demo setup: point at the committed sample run so the pipeline can ingest
# report.json, task.json, trajectory/trace files, screenshots, and logs immediately.
WEBWRIGHT_WORKSPACE_DIR=./fixtures/webwright/sample-run

# For a real runner output, switch to something like:
# WEBWRIGHT_WORKSPACE_DIR=./outputs/webwright/latest

# Optional explicit overrides. Leave blank to rely on auto-discovery from WEBWRIGHT_WORKSPACE_DIR.
WEBWRIGHT_REPORT_PATH=
WEBWRIGHT_TASK_PATH=
WEBWRIGHT_TRAJECTORY_PATH=
WEBWRIGHT_SCREENSHOT_PATHS=
WEBWRIGHT_LOG_PATHS=
WEBWRIGHT_TASK_ID=
